# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Storage Mode: 'local' or 'cloud'
# - 'local': Data stored in browser IndexedDB only (no account needed)
# - 'cloud': Data synced to Supabase (requires sign-in)
VITE_STORAGE_MODE=local

# CORS Proxy URL
# Deploy the Cloudflare Worker from /cloudflare-worker directory
VITE_CORS_PROXY_URL=https://your-worker.workers.dev
