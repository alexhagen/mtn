      "hoursAgo": 24,
      "articles": [
        {
          "title": "Recent Article",
          "link": "https://example.com/recent",
          "pubDate": 1704055200000
        }
      ],
      "expectedTitles": ["Recent Article"]
    },
    {
      "name": "article outside 24 hour window",
