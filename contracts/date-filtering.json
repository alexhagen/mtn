        }
      ],
      "expectedTitles": ["Null Date Article"]
    },
    {
      "name": "custom time window - 12 hours",
      "hoursAgo": 12,
      "articles": [
        {
          "title": "6 hours ago",
          "link": "https://example.com/6h",
          "pubDate": 1704045600000
        },
        {
          "title": "18 hours ago",
          "link": "https://example.com/18h",
          "pubDate": 1704002400000
        }
      ],
      "expectedTitles": ["6 hours ago"]
    },
    {
      "name": "empty array",
      "hoursAgo": 24,
      "articles": [],
