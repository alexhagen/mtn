          "pubDate": 1703894400000
        }
      ],
      "expectedTitles": []
    },
    {
      "name": "mixed articles - some in, some out",
      "hoursAgo": 24,
      "articles": [
        {
          "title": "Recent 1",
          "link": "https://example.com/r1",
          "pubDate": 1704055200000
        },
        {
          "title": "Old 1",
          "link": "https://example.com/o1",
          "pubDate": 1703894400000
        },
        {
          "title": "Recent 2",
          "link": "https://example.com/r2",
          "pubDate": 1704060000000
        }
      ],
      "expectedTitles": ["Recent 1", "Recent 2"]
    },
    {
      "name": "article without pubDate should be included",
      "hoursAgo": 24,
      "articles": [
        {
          "title": "No Date Article",
          "link": "https://example.com/nodate"
        }
      ],
      "expectedTitles": ["No Date Article"]
    },
    {
      "name": "article with null pubDate should be included",
      "hoursAgo": 24,
      "articles": [
        {
          "title": "Null Date Article",
          "link": "https://example.com/null",
