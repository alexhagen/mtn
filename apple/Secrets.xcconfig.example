// Secrets.xcconfig.example
// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored and should never be committed.
//
// Get these values from your Supabase project:
//   https://supabase.com/dashboard/project/_/settings/api
//
// Note: Set SUPABASE_URL to just the hostname (no https://) — xcconfig treats
// "//" as a comment, so the scheme is added automatically in Configuration.swift.

SUPABASE_URL = your-project-id.supabase.co
SUPABASE_ANON_KEY = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
